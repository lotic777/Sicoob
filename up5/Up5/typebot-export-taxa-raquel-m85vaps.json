us {\n    font-size: 13px;\n    font-weight: 500;\n    color: #000000;\n    white-space: nowrap;\n    overflow: hidden;\n    text-overflow: ellipsis;\n  }\n\n  .ml-saldo {\n    background: #D9FDD3;\n    color: #0A8F3C;\n    font-weight: 700;\n    font-size: clamp(13px, 3.5vw, 16px);\n    padding: clamp(6px, 2.5vw, 8px) clamp(10px, 3.2vw, 16px);\n    border-radius: 999px;\n    white-space: nowrap;\n    flex: 0 0 auto;\n    margin-left: auto;\n  }\n\n  body {\n    padding-top: 40px !important;\n  }\n\n  /* Barra de Progresso */\n  .ml-progress {\n    width: 100%;\n    background: #ffffff;\n    padding: 12px 20px;\n    box-sizing: border-box;\n    position: fixed;\n    top: 81px;\n    left: 0;\n    z-index: 999998;\n  }\n\n  .ml-progress-labels {\n    display: flex;\n    justify-content: space-between;\n    font-size: 12px;\n    font-weight: 600;\n    color: #1d9bf0;\n    margin-bottom: 6px;\n  }\n\n  .ml-progress-labels span:last-child {\n    color: #1D9BF0;\n  }\n\n  .ml-progress-bar-bg {\n    width: 100%;\n    height: 8px;\n    background: #E5E7EB;\n    border-radius: 999px;\n  }\n\n  .ml-progress-bar-fill {\n    height: 8px;\n    background: #1D9BF0;\n    width: 0%;\n    border-radius: 999px;\n    transition: width 0.4s ease;\n  }\n</style>\n\n<script>\n  function criarBarraML() {\n    if (document.querySelector(\".ml-user-bar\")) return;\n\n    const bar = document.createElement(\"div\");\n    bar.className = \"ml-user-bar\";\n\n    const left = document.createElement(\"div\");\n    left.className = \"ml-left\";\n\n    const avatar = document.createElement(\"div\");\n    avatar.className = \"ml-avatar\";\n    avatar.innerHTML = `\n      <img src=\"https://s3.typebot.io/public/workspaces/clrftlh3e000liottr58eljzz/typebots/cm2b7ycac001f10ukcmobe5ii/blocks/r1ezt6t5o5ts49f04g9tdolh?v=1764330614571\" alt=\"Karen\">\n    `;\n\n    const info = document.createElement(\"div\");\n    info.className = \"ml-info\";\n    info.innerHTML = `\n      <div class=\"ml-name\"></div>\n    `;\n\n    const saldo = document.createElement(\"div\");\n\n    left.appendChild(avatar);\n    left.appendChild(info);\n    bar.appendChild(left);\n    bar.appendChild(saldo);\n\n    document.body.insertBefore(bar, document.body.firstChild);\n\n    // 🔵 Barra de progresso animada\n    if (!document.querySelector(\".ml-progress\")) {\n      const progressoFinal = 92;\n      const progressoIntermediario = 70;\n\n      const progressBar = document.createElement(\"div\");\n      progressBar.className = \"ml-progress\";\n\n      progressBar.innerHTML = `\n        <div class=\"ml-progress-labels\">\n          <span>Empréstimo em Andamento...</span>\n          <span id=\"progress-text\">0%</span>\n        </div>\n        <div class=\"ml-progress-bar-bg\">\n          <div class=\"ml-progress-bar-fill\" id=\"progress-bar\" style=\"width: 0%;\"></div>\n        </div>\n      `;\n\n      document.body.insertBefore(progressBar, bar.nextSibling);\n\n      let current = 0;\n      const barEl = document.getElementById('progress-bar');\n      const textEl = document.getElementById('progress-text');\n\n      // Fase 1: rápido até 85%\n      const fast = setInterval(() => {\n        if (current >= progressoIntermediario) {\n          clearInterval(fast);\n          // Fase 2: lento até 94%\n          const slow = setInterval(() => {\n            if (current >= progressoFinal) {\n              clearInterval(slow);\n            } else {\n              current++;\n              barEl.style.width = current + '%';\n              textEl.innerText = current + '%';\n            }\n          }, 120); // mais lento\n        } else {\n          current += 5;\n          if (current > progressoIntermediario) current = progressoIntermediario;\n          barEl.style.width = current + '%';\n          textEl.innerText = current + '%';\n        }\n      }, 50); // mais rápido\n    }\n  }\n\n  criarBarraML();\n  setTimeout(criarBarraML, 500);\n  setTimeout(criarBarraML, 1500);\n</script>\n<script>